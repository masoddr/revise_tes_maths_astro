  new Set(
    allAnnales
      .flatMap(item => item.themes || [])
      .map(theme => theme.split(':')[1]?.trim())
      .filter(Boolean)
  )
).sort();

const whatsappNumber = "33616635187";
const whatsappMessageBacAnnales =  "Bonjour, je cherche un accompagnement pour préparer le bac de maths. J'ai vu votre page sur les annales.";
const whatsappBacAnnalesUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessageBacAnnales)}`;
const contactHref = "/#contact";
const coursParticuliersHref = "/professeur-particulier-maths";

/** Approx. first bac maths slot (Métropole) — update when rebuilding for a new session year. */
const bacMathsApprox = new Date(Date.UTC(2026, 5, 16));
const daysUntilBac = Math.ceil(
  (bacMathsApprox.getTime() - Date.now()) / (1000 * 60 * 60 * 24)
);

function formatBacCountdown(days: number): string {
  if (days <= 14) {
    const d = Math.max(1, days);
    return `dans environ ${d} jour${d > 1 ? "s" : ""}`;
  }
  if (days <= 50) return `dans environ ${Math.round(days / 7)} semaines`;
  const months = Math.round(days / 30);
  if (months <= 1) return "dans environ 1 mois";
  return `dans environ ${months} mois`;
}

const showBacUrgencyBanner = daysUntilBac > 0 && daysUntilBac <= 100;
const bacUrgencyCountdownLabel = showBacUrgencyBanner ? formatBacCountdown(daysUntilBac) : null;
