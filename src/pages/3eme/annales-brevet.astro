                      <span class="inline-flex items-center px-1.5 md:px-2.5 py-0.5 md:py-1 rounded text-[10px] md:text-xs font-semibold bg-blue-100 text-blue-800">
                        {item.annee}
                      </span>
                      <span class="text-[10px] md:text-xs text-gray-500 font-medium">
                        {item.type}
                      </span>
                    </div>
                    <h3 class="text-xs md:text-base font-semibold text-gray-900 mb-0.5 md:mb-1 group-hover:text-blue-600 transition-colors leading-tight line-clamp-2">
                      {item.centre}
                    </h3>
                    <p class="text-[10px] md:text-sm text-gray-600">{item.date}</p>
                  </div>
                  
                  {themesList.length > 0 && (
                    <div class="mb-2 md:mb-4">
                      <p class="text-[10px] md:text-xs font-semibold text-gray-700 mb-1 md:mb-2">Thèmes par exercice :</p>
                      <div class="flex flex-wrap gap-1 md:gap-1.5">
                        {(() => {
                          const themesByEx: { [key: string]: string[] } = {};
                          for (const theme of themesList) {
                            const parts = theme.split(':').map((s) => s.trim());
                            const exNumRaw = parts[0];
                            const themeNameRaw = parts[1];
                            if (!exNumRaw || !themeNameRaw) continue;
                            const exKey = exNumRaw;
                            if (!themesByEx[exKey]) {
                              themesByEx[exKey] = [];
                            }
                            if (!themesByEx[exKey].includes(themeNameRaw)) {
                              themesByEx[exKey].push(themeNameRaw);
                            }
                          }
                          return Object.entries(themesByEx).map(([exNum, themeNames]) => (
                            <span
                              class="inline-flex items-center px-1.5 md:px-2.5 py-0.5 rounded text-[9px] md:text-xs font-medium bg-purple-50 text-purple-700 border border-purple-200"
                              data-theme={themeNames.join(' ')}
                            >
                              {exNum}: {themeNames.join(', ')}
                            </span>
                          ));
                        })()}
                      </div>
                    </div>
                  )}
                  
                  {themesList.length === 0 && (
                    <div class="mb-2 md:mb-4">
                      <p class="text-[9px] md:text-xs text-gray-400 italic">Thèmes à renseigner</p>
                    </div>
                  )}
                  
                  <div class="flex gap-1.5 md:gap-2 mt-2 md:mt-4">
                    <a 
                      href={item.sujet} 
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex-1 inline-flex items-center justify-center gap-0.5 md:gap-1.5 px-1.5 md:px-3 py-1.5 md:py-2 bg-gray-900 text-white rounded md:rounded-lg hover:bg-gray-800 transition-colors text-[10px] md:text-xs font-medium shadow-sm hover:shadow-md"
                    >
                      <svg class="w-3 h-3 md:w-3.5 md:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      <span class="hidden sm:inline">Sujet</span>
                    </a>
                    <a 
                      href={item.corrige} 
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex-1 inline-flex items-center justify-center gap-0.5 md:gap-1.5 px-1.5 md:px-3 py-1.5 md:py-2 border-2 border-gray-900 text-gray-900 rounded md:rounded-lg hover:bg-gray-900 hover:text-white transition-colors text-[10px] md:text-xs font-medium shadow-sm hover:shadow-md"
                    >
                      <svg class="w-3 h-3 md:w-3.5 md:h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                      </svg>
                      <span class="hidden sm:inline">Corrigé</span>
                    </a>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
        
        <!-- Empty State -->
        <div id="empty-state" class="hidden text-center py-16">
          <div class="text-6xl mb-4">🔍</div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Aucune annale trouvée</h3>
          <p class="text-gray-600">Essayez de modifier vos filtres</p>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Micro-CTA fin de page -->
  <section class="bg-white py-12 md:py-16 border-t border-gray-100">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="bg-gray-50 rounded-2xl border border-gray-100 p-6 md:p-8">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <div class="max-w-2xl">
              <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">
                Avant de refaire seul : demandez une aide ciblée
              </h2>
              <p class="text-gray-700 leading-relaxed">
                Vous choisissez une annale, vous m’expliquez le point qui bloque, et on transforme l’entraînement en méthode.
                Une séance ciblée peut suffire pour progresser rapidement.
              </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href={contactHref}
                class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-gray-900 text-white rounded-lg font-semibold hover:bg-gray-800 transition-colors shadow-sm"
              >
                Réserver une séance annales brevet
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </a>

              <a
                href={whatsappBrevetAnnalesUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#25D366] text-white rounded-lg font-semibold hover:bg-[#20BA5A] transition-colors shadow-sm"
              >
                Aide sur WhatsApp
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
