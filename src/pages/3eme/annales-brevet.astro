  new Set(
    allAnnales
      .flatMap(item => item.themes || [])
      .map(theme => theme.split(':')[1]?.trim())
      .filter(Boolean)
  )
).sort();

const whatsappNumber = "33616635187";
const whatsappMessageBrevetAnnales =
  "Bonjour, je prépare le brevet de maths et j'aimerais des cours (éventuellement pendant les vacances) pour gratter des points. J'ai vu votre page sur les annales.";
const whatsappBrevetAnnalesUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessageBrevetAnnales)}`;
const contactHref = "#formulaire-contact";
const coursParticuliersHref = "/professeur-particulier-maths";

/** Approx. DNB written tests window — update when rebuilding for a new session year. */
const brevetExamApprox = new Date(Date.UTC(2026, 5, 24));
const daysUntilBrevet = Math.ceil(
  (brevetExamApprox.getTime() - Date.now()) / (1000 * 60 * 60 * 24)
);

function formatBrevetCountdown(days: number): string {
  if (days <= 14) {
    const d = Math.max(1, days);
    return `dans environ ${d} jour${d > 1 ? "s" : ""}`;
  }
  if (days <= 50) return `dans environ ${Math.round(days / 7)} semaines`;
  const months = Math.round(days / 30);
  if (months <= 1) return "dans environ 1 mois";
  return `dans environ ${months} mois`;
}

const showBrevetUrgencyBanner = daysUntilBrevet > 0 && daysUntilBrevet <= 100;
const brevetUrgencyCountdownLabel = showBrevetUrgencyBanner
  ? formatBrevetCountdown(daysUntilBrevet)
  : null;
---

<Layout 
  title="Annales Brevet Maths - Sujets et Corrigés | revise-tes-maths.fr"
  description="Annales brevet maths avec sujets et corrigés détaillés. Préparation efficace au brevet des collèges avec annales corrigées 2024 et 2025."
